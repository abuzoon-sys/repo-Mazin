<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="building_view_tree" model="ir.ui.view">
        <field name="name">building_tree</field>
        <field name="model">building</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="no"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
     <record id="building_view_form" model="ir.ui.view">
        <field name="name">building_form</field>
        <field name="model">building</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="General info">
                            <field name="name"/>
                            <field name="no"/>
                        </group>
                        <group string="Additional info">
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="building_view_search" model="ir.ui.view">
        <field name="name">building_search</field>
        <field name="model">building</field>
        <field name="arch" type="xml">
                <search>
                    <field name="no"/>
                    <field name="code"/>
                    <field name="active"/>
                </search>
        </field>
    </record>
    <record id="building_action" model="ir.actions.act_window">
        <field name="name">building_action</field>
        <field name="res_model">building</field>
    </record>
    <menuitem
        id="building_menu_item"
        name="Building"
        parent="properties_menu"
        action="building_action"
    />

</odoo>