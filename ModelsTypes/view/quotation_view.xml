<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="quotation_view_tree" model="ir.ui.view">
        <field name="name">quotation_tree</field>
        <field name="model">qb.quotation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="quotation_number"/>
                <field name="customer_name"/>
                <field name="date"/>
                <field name="state"/>
                <field name="currency_symbol"/>
                <field name="amount_untaxed"/>
            </tree>
        </field>
    </record>
    <record id="quotation_view_form" model="ir.ui.view">
        <field name="name">quotation_form</field>
        <field name="model">qb.quotation</field>
        <field name="arch" type="xml">
            <form string="Quotation">
                 <header>
                    <button name="action_set_to_draft" type="object" string="Set to Draft"
                            states="confirmed,cancelled" class="btn-secondary"/>
                    <button name="action_confirm" type="object" string="Confirm"
                            states="draft" class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            states="draft,confirmed" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="quotation_number"/>
                            <field name="customer_name"/>
                            <field name="date"/>
                            <field name="state"/>
                            <field name="currency_symbol"/>
                        </group>
                        <group string="Summary">
                            <field name="amount_untaxed" readonly="1"/>
                            <field name="amount_discount" readonly="1"/>
                            <field name="amount_after_discount" readonly="1"/>
                            <field name="amount_tax" readonly="1"/>
                            <field name="amount_total" readonly="1"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids" context="{'default_sequence': 10}">
                                <tree editable="bottom">
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="qty"/>
                                    <field name="unit_price"/>
                                    <field name="discount_type"/>
                                    <field name="discount_value"/>
                                    <field name="tax_percent"/>
                                    <field name="price_before_discount" readonly="1"/>
                                    <field name="discount_amount" readonly="1"/>
                                    <field name="price_subtotal" readonly="1"/>
                                    <field name="tax_amount" readonly="1"/>
                                    <field name="price_total" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="quotation_action" model="ir.actions.act_window">
        <field name="name">quotation</field>
        <field name="res_model">qb.quotation</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
            id="quotation_id_menu"
            name="Quotation"
            parent="estate_root_menu"
            action="quotation_action"

    />

</odoo>