<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="property_view_tree" model="ir.ui.view">
        <field name="name">property_tree</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <tree class="header_custom" decoration-danger="(is_late)">
                <field name="name"/>
                <field name="is_late" invisible="1"/>
                <field name="owner_id"/>
                <field name="description"/>
                <field name="postcode"/>
                <field name="state"/>
                <field name="bedrooms"/>
                <field name="data_availability"/>
                <field name="expected_price"/>
                <field name="selling_price" optional="1"/>
                <field name="garden" optional="1"/>
                <field name="livining_area"/>
                <field name="facades"/>
                <field name="garden_area" />
                <field name="garden_orientation" />
                <field name="tag_ids" widget="many2many_tags"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
     <record id="property_view_form" model="ir.ui.view">
        <field name="name">property_form</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_open_related_owner"
                                type="object" icon="fa-user" string="Owner"
                                attrs="{'invisible': [('owner_id', '=', False)]}"/>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"  attrs="{'invisible': [('active', '=', True)]}"/>
                    <widget name="web_ribbon" title="Sold" bg_color="text-bg-success"  attrs="{'invisible': [('state', '!=', 'sold')]}"/>
                    <header>
                        <button name="action_draft" type="object" class="btn-primary" string="Set Draft"
                                attrs="{'invisible': [('state', 'in', ['draft', 'closed'])]}"/>
<!--                        <button name="action" type="object" class="btn-primary" string="Action"  />-->
                        <button name="action_pending" type="object" class="btn-secondary" string="SET PENDING"/>
                        <button name="action_sold" type="object" class="btn-success" string="SET SOLD" />
                        <field name="state" widget="statusbar" options="{'clickable':1}"/>
                    </header>
                    <div class ="oe_title">
                        <label for="ref"/>
                        <h1>
                            <field name="ref" attrs="{'readonly':[('state','!=', 'draft')]}"/>
                        </h1>
                        <label for="name"/>
                        <h3>
                            <field name="name" attrs="{'readonly': [('state', '=', 'closed')]}"/>
                        </h3>
                    </div>
                    <group>
                        <group string="General info">
                            <field name="description" attrs="{'readonly': [('state', '=', 'closed')]}"/>
                            <field name="postcode" attrs="{'readonly': [('state', '=', 'closed')]}"/>
                            <field name="bedrooms" attrs="{'readonly': [('state', '=', 'closed')]}"/>
                            <field name="data_availability" attrs="{'readonly': [('state', '=', 'closed')]}"/>
                            <field name="expected_price" attrs="{'readonly': [('state', '=', 'closed')]}"/>
                            <field name="expected_selling_date" attrs="{'readonly': [('state', '=', 'closed')]}"/>
                            <field name="diff" attrs="{'readonly': [('state', '=', 'closed')]}"/>
                            <field name="active" attrs="{'readonly': [('state', '=', 'closed')]}"/>
                            <field name="is_late"  />
                        </group>
                        <group string="Additional info">
                            <field name="owner_id"/>
                            <field name="owner_address"/>
                            <field name="owner_phone"/>
                            <field name="selling_price" optional="1"/>
                            <field name="garden" optional="1"/>
                            <field name="livining_area"/>
                            <field name="facades"/>
                            <field name="garden_area" />
                            <field name="garden_orientation" />
                            <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="bedrooms">
                            <field name="line_ids">
                                <tree>
                                    <field name="description"/>
                                     <field name="area"/>
                                </tree>
                            </field>

                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="property_action" model="ir.actions.act_window">
        <field name="name">property_action</field>
        <field name="res_model">property</field>
    </record>

    <record id="property_closed_server_action" model="ir.actions.server">
        <field name="name">Property Close Action</field>
        <field name="model_id" ref="model_property"/>
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_closed()
        </field>
    </record>
    <record id="change_state_server_action" model="ir.actions.server">
        <field name="name">Change State Action</field>
        <field name="model_id" ref="model_property"/>
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_open_change_state_wizard()
        </field>
    </record>
    <record id="Property:check_selling_date_cron" model="ir.cron">
        <field name="name">check selling date</field>
        <field name="model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">model.check_expected_selling_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
    <menuitem
        id="properties_menu_item"
        name="Properties"
        parent="properties_menu"
        action="property_action"
    />

</odoo>