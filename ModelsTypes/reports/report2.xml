<odoo>
    <record id="property_report" model="ir.actions.report">
        <field name="name">Property Report</field>
        <field name="model">property</field>
        <field name="report_type">qweb-html</field>
        <field name="binding_model_id" ref="model_property"/>
        <field name="binding_type">report</field>
        <field name="report_name">ModelsTypes.property_report_temp</field>
    </record>
    <template id="property_report_temp">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="rec">
                    <h>Property Report abuzoon</h>
                    <style>
                        .report-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-top: 15px;
                            font-size: 13px;
                        }

                        .report-table thead {
                            background-color: #2C3E50;
                            color: #FFFFFF;
                        }

                        .report-table th {
                            padding: 8px;
                            text-align: left;
                            font-weight: bold;
                            border: 1px solid #dddddd;
                        }

                        .report-table td {
                            padding: 8px;
                            border: 1px solid #dddddd;
                        }

                        .report-table tbody tr:nth-child(even) {
                            background-color: #f7f7f7;
                        }

                        .text-right {
                            text-align: right;
                        }

                        .text-center {
                            text-align: center;
                        }
                    </style>
                     <table class="report-table">
                         <thead>
                              <tr>
                                  <th colspan="4" class="text-center">General Information</th>
                              </tr>
                         </thead>
                         <tbody>
                             <tr>
                                <td><strong>Name</strong></td>
                                <td><t t-esc="rec.name"/></td>
                                <td><strong>Postcode</strong></td>
                                <td><t t-esc="rec.postcode"/></td>
                             </tr>
                         </tbody>
                         <thead>
                             <tr>
                                 <th colspan="4" class="text-center">Additional Information</th>
                             </tr>
                         </thead>
                         <tbody>
                           <tr>
                               <td><strong>Owner</strong></td>
                               <td><span t-field="rec.owner_id"/></td>
                               <td><strong>Phone</strong></td>
                               <td><t t-esc="rec.owner_phone"/></td>
                           </tr>
                        </tbody>
                     </table>
                     <br/>
                     <table>
                         <thead>
                             <th>Description</th>
                             <th>Area(m2)</th>
                         </thead>
                         <tbody>
                             <t t-foreach="rec.line_ids" t-as="line">
                                 <tr>
                                     <td>
                                        <t t-esc="line.description"/>
                                     </td>
                                     <td>
                                         <t t-esc="line.area"/>
                                     </td>
                                 </tr>
                             </t>
                         </tbody>
                     </table>
                </t>
            </t>
        </t>
    </template>
</odoo>